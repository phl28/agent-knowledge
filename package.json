{
  "name": "@convex-dev/agent-knowledge",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "description": "Convex component for agent memory backed by Convex vector search and Neo4j graph traversal.",
  "type": "module",
  "main": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./convex.config": "./dist/component/convex.config.js",
    "./convex.config.js": "./dist/component/convex.config.js",
    "./chunking": {
      "types": "./dist/client/chunking.d.ts",
      "import": "./dist/client/chunking.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ai": "^5.0.0",
    "convex": "^1.29.0",
    "neo4j-driver": "^5.28.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "ai": ">=5.0.0",
    "convex": ">=1.29.0"
  }
}
